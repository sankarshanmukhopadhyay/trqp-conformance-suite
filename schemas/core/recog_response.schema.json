{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "authority_id",
    "statement"
  ],
  "properties": {
    "authority_id": {
      "type": "string"
    },
    "subject_authority_id": {
      "type": "string"
    },
    "statement": {
      "type": "object",
      "required": [
        "recognized",
        "reason"
      ],
      "properties": {
        "recognized": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "recognized_since": {
          "type": [
            "string",
            "null"
          ]
        },
        "valid_until": {
          "type": [
            "string",
            "null"
          ]
        },
        "governance_reference": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "entity_id": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "properties": {
        "time_evaluated": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 timestamp when the recognition decision was evaluated."
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 timestamp after which this response should not be trusted without re-query."
        }
      },
      "description": "Freshness envelope. SHOULD be present; required by TSPP AL1+ deployments."
    }
  },
  "additionalProperties": true,
  "oneOf": [
    {
      "required": [
        "subject_authority_id"
      ]
    },
    {
      "required": [
        "entity_id"
      ]
    }
  ]
}
