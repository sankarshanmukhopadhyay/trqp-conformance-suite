{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directory-publication-manifest.schema.json",
  "title": "Directory Publication Manifest",
  "type": "object",
  "required": [
    "directory_id",
    "published_at",
    "entries_digest",
    "artifacts"
  ],
  "properties": {
    "directory_id": {
      "type": "string"
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "entries_digest": {
      "type": "object",
      "required": [
        "sha256"
      ],
      "properties": {
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "sha256",
          "media_type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "media_type": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "signing": {
      "type": "object",
      "properties": {
        "algorithm": {
          "type": "string"
        },
        "public_key_ref": {
          "type": "string"
        },
        "signature_ref": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}