{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "authority_id",
    "entity_id",
    "action",
    "decision"
  ],
  "properties": {
    "authority_id": {
      "type": "string"
    },
    "entity_id": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "resource": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision": {
      "type": "object",
      "required": [
        "authorized",
        "reason"
      ],
      "properties": {
        "authorized": {
          "type": "string",
          "enum": [
            "true",
            "false",
            "indeterminate"
          ]
        },
        "reason": {
          "type": "string"
        },
        "valid_from": {
          "type": [
            "string",
            "null"
          ]
        },
        "valid_until": {
          "type": [
            "string",
            "null"
          ]
        },
        "assertion_reference": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "properties": {
        "time_evaluated": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 timestamp when the authorization decision was evaluated."
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 timestamp after which this response should not be trusted without re-query."
        }
      },
      "description": "Freshness envelope. SHOULD be present; required by TSPP AL1+ deployments."
    }
  },
  "additionalProperties": true
}
