{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/trqp/schemas/registrar.schema.json",
  "title": "Registrar Listing",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable registrar identifier (DID or other URI)."
    },
    "name": {
      "type": "string"
    },
    "jurisdiction": {
      "type": "string",
      "description": "Jurisdiction / authority scope (e.g., ISO 3166 country code or formal designation)."
    },
    "governance_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy_uri": {
          "type": "string"
        },
        "policy_hash": {
          "type": "string",
          "description": "Hash of the policy artifact (e.g., SHA-256)."
        }
      },
      "required": [
        "policy_uri",
        "policy_hash"
      ]
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assurance_level": {
          "type": "string",
          "enum": [
            "AL1",
            "AL2",
            "AL3",
            "AL4"
          ]
        },
        "evidence_bundle_uri": {
          "type": "string"
        },
        "last_audit": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "assurance_level"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "under_review",
        "approved",
        "active",
        "suspended",
        "revoked",
        "archived"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "name",
    "jurisdiction",
    "status",
    "updated_at"
  ]
}
