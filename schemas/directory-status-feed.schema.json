{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directory-status-feed.schema.json",
  "title": "Directory Status Feed",
  "type": "object",
  "required": [
    "directory_id",
    "generated_at",
    "events"
  ],
  "properties": {
    "directory_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "event_id",
          "type",
          "entry_id",
          "at"
        ],
        "properties": {
          "event_id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "issued",
              "updated",
              "suspended",
              "revoked",
              "removed",
              "incident"
            ]
          },
          "entry_id": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "type": "string"
          },
          "refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}