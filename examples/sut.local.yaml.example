# SECURITY WARNING: This file contains example credentials for local testing only.
# Never use these values or layout in production without replacing them.
# Copy to examples/sut.local.yaml and set deployment-specific secrets before use.
base_url: "http://127.0.0.1:8000"
state_reference: "fixtureset:v1"
default_headers:
  Accept: "application/json"
api_key: "demo-secret"
# Generate a signing key for local runs, for example:
# python -c "from nacl.signing import SigningKey; from nacl.encoding import Base64Encoder; print(SigningKey.generate().encode(Base64Encoder).decode())"
signing_key_b64: "REPLACE_WITH_BASE64_ED25519_PRIVATE_KEY"

# Optional: override test-case identifiers so real SUTs can run without modifying core tests.
# All fields default to the did:example:* placeholders shipped with the test suite.
# identifiers:
#   authority_id: "did:example:your-authority"
#   entity_id: "did:example:your-entity"
#   subject_authority_id: "did:example:your-subject-authority"
#   action: "your-action"
