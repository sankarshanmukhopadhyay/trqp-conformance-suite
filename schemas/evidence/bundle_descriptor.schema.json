{
  "$id": "https://schemas.trqp.example/evidence/bundle_descriptor.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TRQP CTS Evidence Bundle Descriptor",
  "type": "object",
  "required": [
    "bundle_version",
    "run",
    "artifacts",
    "artifact_index"
  ],
  "properties": {
    "bundle_version": {
      "type": "string"
    },
    "run": {
      "type": "object"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "artifact_index": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "path",
          "produced_by"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "artifact_kind": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "type": "string"
          },
          "produced_by": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "media_type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "tis_projection": {
      "type": "object",
      "description": "Optional Trust Infrastructure Schemas projection metadata for downstream assurance workflows.",
      "properties": {
        "tis_version": {
          "type": "string"
        },
        "evidence_bundle_manifest_schema": {
          "type": "string"
        },
        "conformance_declaration_schema": {
          "type": "string"
        },
        "decision_receipt_schema": {
          "type": "string"
        },
        "projected_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "source_artifact",
              "tis_role"
            ],
            "properties": {
              "source_artifact": {
                "type": "string"
              },
              "tis_role": {
                "type": "string"
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
