{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/trqp/schemas/grid-status-feed.schema.json",
  "title": "GRID Status Feed",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "feed_id": {
      "type": "string"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "issuer": {
      "type": "string",
      "description": "Identifier of the directory operator / feed issuer."
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "registrar_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "suspended",
              "revoked",
              "archived"
            ]
          },
          "effective_at": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "registrar_id",
          "status",
          "effective_at"
        ]
      }
    },
    "proof": {
      "type": "object",
      "description": "Cryptographic proof object (format is implementation-specific)."
    }
  },
  "required": [
    "feed_id",
    "issued_at",
    "issuer",
    "entries"
  ]
}
